---
profile: basic

exclude_paths:
  # syntax-check loads vault-encrypted group_vars/secrets.yaml; CI has no vault password
  - run.yaml

skip_list:
  - command-instead-of-module # curl installers and nfs mount/remount are deliberate shell usage
  - jinja[invalid] # false positive: routeros assert templates need play vars lint cannot provide
  - name[casing] # task names are lowercase throughout; mass rename is churn, not a behavior fix
  - partial-become[task] # become is set at play level in run.yaml; lint evaluates roles standalone
  - role-name # ai-dev is referenced by plays and inventory; renaming the role dir is out of scope
  - var-naming[no-role-prefix] # established var names shared via group_vars; renaming is risky
  - yaml[line-length] # single long line in common/swap-file.yaml; role edits deferred
