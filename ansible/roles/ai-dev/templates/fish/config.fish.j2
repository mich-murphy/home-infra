{# Managed by Ansible — ai-dev role. Ported from /home/michael/nixos/modules/home/shell/fish.nix
   plus the fish-relevant bits of modules/home/shell/cli.nix (eza/fzf/zoxide) and direnv.nix.
   Palette interpolation pulls from ansible/roles/ai-dev/vars/main.yaml. #}

# --- Login shell environment --------------------------------------------------
if status is-login
    set -x BROWSER firefox
end

# --- Interactive shell only ---------------------------------------------------
if status is-interactive
    # Vi keybindings + quiet greeting
    set -g fish_key_bindings fish_vi_key_bindings
    set -g fish_greeting

    # TokyoNight Night fish colors
    set -g fish_color_normal {{ tokyonight.fg }}
    set -g fish_color_command {{ tokyonight.aqua }}
    set -g fish_color_keyword {{ tokyonight.purple }}
    set -g fish_color_quote {{ tokyonight.yellow }}
    set -g fish_color_redirection {{ tokyonight.fg }}
    set -g fish_color_end {{ tokyonight.orange }}
    set -g fish_color_option {{ tokyonight.purple }}
    set -g fish_color_error {{ tokyonight.red }}
    set -g fish_color_param {{ tokyonight.purple0 }}
    set -g fish_color_comment {{ tokyonight.comment }}
    set -g fish_color_selection --background={{ tokyonight.bg2 }}
    set -g fish_color_search_match --background={{ tokyonight.bg2 }}
    set -g fish_color_operator {{ tokyonight.green }}
    set -g fish_color_escape {{ tokyonight.purple }}
    set -g fish_color_autosuggestion {{ tokyonight.comment }}
    set -g fish_pager_color_progress {{ tokyonight.comment }}
    set -g fish_pager_color_prefix {{ tokyonight.aqua }}
    set -g fish_pager_color_completion {{ tokyonight.fg }}
    set -g fish_pager_color_description {{ tokyonight.comment }}
    set -g fish_pager_color_selected_background --background={{ tokyonight.bg2 }}

    # TokyoNight LS_COLORS (directories/links emphasized with palette accents)
    set -x LS_COLORS "di=38;2;122;162;247:ln=38;2;125;207;255:so=38;2;187;154;247:pi=38;2;224;175;104:ex=38;2;158;206;106:bd=38;2;255;158;100:cd=38;2;255;158;100:or=38;2;247;118;142:mi=38;2;247;118;142:su=38;2;247;118;142:sg=38;2;224;175;104:tw=38;2;158;206;106:ow=38;2;125;207;255"

    # fzf colors keyed to TokyoNight palette
    set -x FZF_DEFAULT_OPTS "\
--highlight-line \
--info=inline-right \
--ansi \
--layout=reverse \
--border=none \
--height=60 \
--prompt='∷ ' \
--pointer='▶' \
--marker='⇒' \
--color=bg+:{{ tokyonight.bg2 }} \
--color=bg:{{ tokyonight.bg_dark }} \
--color=border:{{ tokyonight.teal }} \
--color=fg:{{ tokyonight.fg }} \
--color=gutter:{{ tokyonight.bg_dark }} \
--color=header:{{ tokyonight.orange }} \
--color=hl+:{{ tokyonight.cyan }} \
--color=hl:{{ tokyonight.cyan }} \
--color=info:{{ tokyonight.bg4 }} \
--color=marker:{{ tokyonight.magenta }} \
--color=pointer:{{ tokyonight.magenta }} \
--color=preview-bg:{{ tokyonight.bg_dark }} \
--color=preview-fg:{{ tokyonight.fg }} \
--color=prompt:{{ tokyonight.cyan }} \
--color=query:{{ tokyonight.fg }}:regular \
--color=scrollbar:{{ tokyonight.teal }} \
--color=separator:{{ tokyonight.orange }} \
--color=spinner:{{ tokyonight.magenta }}"
    set -x FZF_DEFAULT_COMMAND "fd --type f --hidden --exclude .git"
    set -x FZF_CTRL_T_COMMAND "fd --type f --hidden --exclude .git"
    set -x FZF_ALT_C_COMMAND "fd --type d --hidden --exclude .git"

    # --- Aliases / abbreviations ---------------------------------------------
    # From fish.nix shellAliases
    alias cat='bat'

    # From home.nix shellAliases (ls = "eza -la") + cli.nix programs.eza (icons=auto, --group-directories-first)
    alias ls='eza --icons=auto --group-directories-first -la'
    alias lt='eza --icons=auto --group-directories-first --tree'

    # --- Tool initialisation -------------------------------------------------
    if type -q starship
        starship init fish | source
    end
    if type -q fzf
        fzf --fish | source
    end
    if type -q zoxide
        zoxide init fish | source
    end
    if type -q direnv
        direnv hook fish | source
    end

    # --- Plugins (autopair, sponge) -----------------------------------------
    # On non-Nix targets these are expected to be installed via fisher in
    # bootstrap.yaml; source their entry points when present.
    for plugin_dir in ~/.config/fish/plugins/autopair ~/.config/fish/plugins/sponge
        if test -d $plugin_dir
            for f in $plugin_dir/conf.d/*.fish
                source $f
            end
        end
    end
end
