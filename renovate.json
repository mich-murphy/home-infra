{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "docker:enableMajor",
    "default:automergeDigest",
    "customManagers:githubActionsVersions",
    ":rebaseStalePrs"
  ],
  "semanticCommits": "enabled",
  "branchPrefix": "actions-renovate/",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 5,
  "branchConcurrentLimit": 5,
  "rebaseWhen": "conflicted",
  "automergeStrategy": "rebase",
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOSVVulnerabilitySummary": "unresolved",
  "major": {
    "automerge": false,
    "dependencyDashboardApproval": true
  },
  "kubernetes": {
    "managerFilePatterns": ["/kubernetes/.+\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "description": "Require approval for high-risk infrastructure updates",
      "matchPackageNames": [
        "/^cilium$/",
        "/^cilium\\//",
        "/^external-secrets$/",
        "/^external-secrets\\//",
        "/^fluxcd\\/flux2$/",
        "/^ghcr\\.io\\/fluxcd\\//",
        "/^ghcr\\.io\\/immich-app\\//",
        "/^hashicorp\\/terraform$/",
        "/^local$/",
        "/^mariadb$/",
        "/^miniflux\\/miniflux$/",
        "/^onepassword$/",
        "/^openebs$/",
        "/^openebs\\//",
        "/^postgres$/",
        "/^proxmox$/",
        "/^redis$/",
        "/^terraform-provider-.*/",
        "/^traefik$/"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Linuxserver.io Qbittorrent",
      "matchPackageNames": ["/^(gh|ls)cr\\.io\\/linuxserver\\/qbittorrent/"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-r(?<build>\\d+)-ls(?<revision>.+)$"
    },
    {
      "description": "Linuxserver.io Sabnzbd",
      "matchPackageNames": ["/^(gh|ls)cr\\.io\\/linuxserver\\/sabnzbd/"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<build>.+)$"
    },
    {
      "description": "Linuxserver.io Tautulli",
      "matchPackageNames": ["/^(gh|ls)cr\\.io\\/linuxserver\\/tautulli/"],
      "versioning": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<build>.+)$"
    },
    {
      "description": "Linuxserver.io Arrs",
      "matchPackageNames": [
        "/^(gh|ls)cr\\.io\\/linuxserver\\/(radarr|sonarr|lidarr|prowlarr)/"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)-ls(?<revision>.+)$"
    },
    {
      "description": "Plex Media Server",
      "matchPackageNames": ["/^plexinc\\/pms-docker/"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)-(?<revision>.+)$"
    },
    {
      "description": "Manual Approval for Immich Server and Machine Learning",
      "matchPackageNames": [
        "/^ghcr\\.io\\/immich-app\\/(immich-server|immich-machine-learning)/"
      ],
      "automerge": false
    },
    {
      "description": "Disable Immich Database and Cache Updates",
      "matchPackageNames": [
        "/^(ghcr|docker)\\.io\\/(immich-app|valkey)\\/(postgres|valkey)/"
      ],
      "enabled": false
    }
  ]
}
